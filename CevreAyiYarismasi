##  Veritabanı Yapısı

```sql
-- Personel tablosu
CREATE TABLE Personel (
    SicilNo     VARCHAR(20) PRIMARY KEY,
    Ad          NVARCHAR(100),
    Departman   NVARCHAR(100),
    OdulKazandi BIT DEFAULT 0
);

-- Sorular tablosu
CREATE TABLE Sorular (
    Id          INT IDENTITY PRIMARY KEY,
    Metin       NVARCHAR(MAX),
    SikA        NVARCHAR(500),
    SikB        NVARCHAR(500),
    SikC        NVARCHAR(500),
    SikD        NVARCHAR(500),
    DogruCevap  CHAR(1),
    Zorluk      INT,             -- 1: Kolay, 2: Orta, 3: Zor
    FotoRef     NVARCHAR(50)     -- NULL veya "[Foto: N]"
);

-- Katılım kayıtları
CREATE TABLE Katilimlar (
    Id          INT IDENTITY PRIMARY KEY,
    SicilNo     VARCHAR(20),
    Tarih       DATE,
    Puan        INT,
    DogruSayisi INT,
    YanlisSayisi INT,
    KatilimZamani DATETIME DEFAULT GETDATE()
);
```



